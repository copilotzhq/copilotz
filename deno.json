{
  "name": "@copilotz/copilotz",
  "description": "Copilotz Lib",
  "version": "0.54.2",
  "license": "MIT",
  "exports": {
    ".": "./index.ts",
    "./resources": "./resources/index.ts",
    "./tokens": "./runtime/tokens/index.ts",
    "./server": "./server/index.ts",
    "./create": "./create/mod.ts",
    "./scripts/ascii-logo": "./scripts/ascii-logo.ts",
    "./scripts/compile-cli": "./scripts/compile-cli.ts",
    "./scripts/migrate-tenant-namespace-graph": "./scripts/migrate-tenant-namespace-graph.ts"
  },
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "net",
    "otel",
    "raw-imports"
  ],
  "imports": {
    "@/": "./",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@bradenmacdonald/s3-lite-client": "jsr:@bradenmacdonald/s3-lite-client@^0.9.4",
    "ajv": "npm:ajv@8.17.1",
    "ajv-formats": "npm:ajv-formats@3.0.1",
    "croner": "npm:croner@9.0.0",
    "json-schema-to-ts": "npm:json-schema-to-ts@3.1.1",
    "jq-wasm": "npm:jq-wasm@3.0.0-jq-1.8.2/inline",
    "modelcontextprotocol/sdk/client": "npm:@modelcontextprotocol/sdk@1.17.0/client",
    "omnipg": "jsr:@oxian/ominipg@0.8.1",
    "omnipg/auto": "jsr:@oxian/ominipg@0.8.1/auto",
    "omnipg/pglite": "jsr:@oxian/ominipg@0.8.1/pglite",
    "omnipg/worker": "jsr:@oxian/ominipg@0.8.1/worker",
    "ulid": "jsr:@std/ulid@1.0.0",
    "yaml": "npm:yaml@2.8.0",
    "zod": "npm:zod@3.23.8"
  },
  "tasks": {
    "gen:skills": "deno run -A scripts/generate-skill-js.ts",
    "compile:cli": "deno run -A scripts/compile-cli.ts",
    "test:examples": "deno run -A examples/test-examples.ts"
  },
  "lock": false
}
